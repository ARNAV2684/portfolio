# ─────────────────────────────────────────────────────────────────────────────
# Contact backend — Supabase (primary) + Resend (email notification)
# Copy this file to `.env.local` and fill in real values. NEVER commit .env.local.
# See CLAUDE.md §9 for the full spec.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase — project URL is public; the SERVICE ROLE key is server-only (never
# expose it to the client / never prefix it with NEXT_PUBLIC_).
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend — API key for sending the notification email.
RESEND_API_KEY=

# Where contact form notifications are delivered.
CONTACT_TO_EMAIL=arug2004@gmail.com

# The "from" address Resend sends as. Must be a verified domain/sender in Resend.
# During testing you can use Resend's sandbox sender: onboarding@resend.dev
RESEND_FROM_EMAIL=Portfolio Contact <onboarding@resend.dev>

# ─────────────────────────────────────────────────────────────────────────────
# Alternative backend (optional): Formspree-only — no DB, no Resend.
# If you set this, the route handler will forward submissions to Formspree
# instead of Supabase+Resend. See app/api/contact/route.ts for the toggle.
# ─────────────────────────────────────────────────────────────────────────────
# FORMSPREE_ENDPOINT=
